# Local SQLite database for lead capturee
DATABASE_URL="file:./prisma/dev.db"

# --- Email notifications (Resend) ---------------------------------------
# When a teardown is submitted, a notification email is sent via Resend.
# Get a key at https://resend.com (sign up with the inbox below so you can
# use the built-in onboarding@resend.dev sender with no domain verification).
# If RESEND_API_KEY is unset, email is skipped and the form still works.
RESEND_API_KEY=""

# Where new-lead notifications are sent.
NOTIFY_EMAIL="touchtabletapps@gmail.com"

# Sender shown on the notification. The default works with any Resend
# account; use a verified-domain address once you have one.
# NOTIFY_FROM="Maubourg Studio <onboarding@resend.dev>"
